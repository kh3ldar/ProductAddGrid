{
  "name": "productaddgrid-pcf",
  "version": "1.0.600",
  "description": "Configurable PCF control for adding products to opportunities, quotes, and custom entities in Dataverse",
  "scripts": {
    "build": "pcf-scripts build",
    "clean": "pcf-scripts clean",
    "lint": "eslint ProductAddGrid",
    "lint:fix": "eslint ProductAddGrid --fix",
    "rebuild": "pcf-scripts rebuild",
    "start": "pcf-scripts start",
    "start:watch": "pcf-scripts start watch",
    "refreshTypes": "pcf-scripts refreshTypes",
    "test:local": "echo 'Open ProductAddGrid/test/index.html in your browser for local testing'",
    "dev": "npm run start:watch"
  },
  "dependencies": {
    "@fluentui/react": "^8.120.0",
    "react": "16.14.0",
    "react-dom": "16.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.51",
    "@playwright/test": "^1.56.1",
    "@types/node": "^25.2.2",
    "@types/powerapps-component-framework": "^1.3.16",
    "@types/react": "^16.14.60",
    "@types/react-dom": "^16.9.24",
    "baseline-browser-mapping": "^2.9.19",
    "dotenv": "^17.2.3",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.15.0",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "playwright": "^1.56.1",
    "react": "^16.14.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
